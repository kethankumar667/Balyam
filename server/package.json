{
  "name": "multiplayer-games-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit",
